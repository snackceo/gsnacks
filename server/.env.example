# Pricing lock secret (used to sign/verify checkout-preview pricing)
# Set to a strong random string in production.
PRICING_SECRET=change_me

# Optional fallback hub coordinates (used if no hub store is configured)
# HUB_LAT=42.3314
# HUB_LNG=-83.0458

# Google Maps (routing/distance)
# GOOGLE_MAPS_API_KEY=your_api_key

# MongoDB
# MONGODB_URI=mongodb://localhost:27017/gsnacks

# Stripe
# STRIPE_SECRET_KEY=sk_test_xxx

# JWT secret (used as fallback if PRICING_SECRET is not set)
# JWT_SECRET=another_secret
