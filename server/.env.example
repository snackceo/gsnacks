# ============================================
# GSNACKS SERVER ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# DATABASE
# ============================================
MONGODB_URI=mongodb://localhost:27017/gsnacks

# ============================================
# AUTHENTICATION & SECRETS
# ============================================
JWT_SECRET=your_jwt_secret_key_here_change_in_production
SESSION_SECRET=your_session_secret_key_here_change_in_production

# ============================================
# GEMINI / GOOGLE APIs
# ============================================
# Get from: https://console.cloud.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ============================================
# CLOUDINARY (Receipt Image Storage)
# ============================================
# CRITICAL: Never use frontend-only Cloudinary
# Receipts are legal artifacts - store server-side only
#
# Get from: https://cloudinary.com/console
#
# OPTION 1: Use CLOUDINARY_URL (Easiest - single variable)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
#
# OPTION 2: Use individual fields (Alternative)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
#
# Note: Use either OPTION 1 or OPTION 2, not both
#
# Optional: Override default folder
CLOUDINARY_RECEIPT_FOLDER=gsnacks/receipts

# Optional: Product image fallback (Cloudinary-hosted "image unavailable" asset)
PRODUCT_IMAGE_FALLBACK_URL=https://res.cloudinary.com/demo/image/upload/w_600,h_600,c_fill,l_text:arial_36:Image%20Unavailable/sample.jpg

# ============================================
# STRIPE (Payment Processing)
# ============================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# SENTRY (Error Tracking)
# ============================================
# Optional - get from https://sentry.io/
SENTRY_DSN=your_sentry_dsn_here

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# QUEUE / REDIS (BullMQ receipt processing)
# ============================================
# Enable BullMQ receipt queue worker
ENABLE_RECEIPT_QUEUE=false
# Redis connection string (required for receipt queue)
REDIS_URL=redis://localhost:6379

# ============================================
# FRONTEND
# ============================================
# Used in index.js to serve static files
FRONTEND_BUILD_DIR=../dist

# ============================================
# OPTIONAL: Store Configuration
# ============================================
# Owner username (super-admin)
OWNER_USERNAME=owner
# Driver usernames (comma-separated)
DRIVER_USERNAMES=driver1,driver2

# ============================================
# OPTIONAL: Maintenance Mode
# ============================================
# MAINTENANCE_MODE=false
# MAINTENANCE_MESSAGE=System maintenance in progress
